{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": false,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,

    "baseUrl": ".",

    "types": ["node"],

    "paths": {
      "@/*": ["frontend/src/*"],
      "@shared/*": ["backend/shared/*"]
    }
  },

  "include": ["backend", "api"],
  "exclude": ["node_modules"]
}